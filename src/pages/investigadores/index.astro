---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ResearcherCard from '../../components/ResearcherCard.astro';

const all     = (await getCollection('researchers')).sort((a, b) => a.data.name.localeCompare(b.data.name, 'es'));
const leader  = all.filter(r =>  r.data.codec_role.includes('Líder'));
const members = all.filter(r => !r.data.codec_role.includes('Líder'));
---

<Base title="Integrantes">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900">Integrantes</h1>
      <p class="text-gray-500 mt-2 text-lg">Conoce al equipo del grupo CODEC</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
      <p class="hidden sm:block text-xs font-bold text-gray-400 uppercase tracking-widest">Líder</p>
      <div class="hidden sm:flex sm:col-span-3 items-center gap-2">
        <span class="text-xs font-bold text-gray-400 uppercase tracking-widest shrink-0">Investigadoras/es</span>
        <span class="flex-1 h-px bg-gray-200"></span>
      </div>
      {[...leader, ...members].map(r => <ResearcherCard researcher={r} />)}
    </div>

    <a href="/antiguos-integrantes"
       class="mt-12 flex items-center justify-center gap-3 rounded-2xl border border-codec/25 bg-codec/5 hover:bg-codec/10 px-5 py-4 transition-colors">
      <div class="w-3 h-3 rounded-full shrink-0 bg-amber-600"></div>
      <span class="text-sm font-semibold text-amber-700">Conoce nuestra historia y antiguos integrantes</span>
    </a>
  </div>
</Base>
