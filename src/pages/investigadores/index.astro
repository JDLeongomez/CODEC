---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ResearcherCard from '../../components/ResearcherCard.astro';

const researchers = (await getCollection('researchers')).sort((a, b) => a.data.weight - b.data.weight);
---

<Base title="Investigadores">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900">Investigadores</h1>
      <p class="text-gray-500 mt-2 text-lg">Conoce al equipo del grupo CODEC</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
      {researchers.map(r => <ResearcherCard researcher={r} />)}
    </div>
  </div>
</Base>
