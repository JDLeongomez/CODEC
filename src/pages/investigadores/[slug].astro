---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import Icon from '../../components/Icon.astro';
import { LINES } from '../../data/lines';
import { slug as toSlug } from '../../utils';

export async function getStaticPaths() {
  const researchers = await getCollection('researchers');
  return researchers.map(r => ({ params: { slug: toSlug(r.id) }, props: { researcher: r } }));
}

const { researcher } = Astro.props;
const { name, academic_role, codec_role, email, avatar, bio_short_es,
        interests_es, education, scholar, orcid, scopus, cvlac,
        researchgate, website, twitter, labs, semilleros } = researcher.data;

const { Content } = await researcher.render();

const labEntries       = await Promise.all((labs ?? []).map(ref => getEntry(ref)));
const semilleroEntries = await Promise.all((semilleros ?? []).map(ref => getEntry(ref)));

const allPublications  = await getCollection('publications');
const myPublications   = allPublications
  .filter(pub => pub.data.internal_authors?.some(ref => toSlug(ref.id) === toSlug(researcher.id)))
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));

const lineIds = [...new Set([
  ...labEntries.map(l => l?.data.research_line),
  ...semilleroEntries.map(s => s?.data.research_line),
])].filter(Boolean) as string[];

const socialLinks = [
  { href: website,                                          label: 'Sitio web',     icon: 'globe' },
  { href: scholar,                                          label: 'Google Scholar', icon: 'google-scholar' },
  { href: orcid ? `https://orcid.org/${orcid}` : undefined, label: 'ORCID',          icon: 'orcid' },
  { href: scopus,                                           label: 'Scopus',         icon: 'scopus' },
  { href: cvlac,                                            label: 'CvLAC',          icon: 'cvlac' },
  { href: researchgate,                                     label: 'ResearchGate',   icon: 'researchgate' },
  { href: `mailto:${email}`,                                label: 'Email',          icon: 'envelope' },
].filter(l => l.href);
---

<Base title={name} description={bio_short_es}>
  <div class="max-w-4xl mx-auto px-6 py-16">

    <nav class="text-sm text-gray-400 mb-8">
      <a href="/investigadores" class="hover:text-codec transition-colors">Investigadores</a>
      <span class="mx-2">›</span>
      <span class="text-gray-600">{name}</span>
    </nav>

    <div class="flex flex-col sm:flex-row gap-8 mb-12">
      <div class="shrink-0">
        <img src={avatar} alt={name} class="w-36 h-36 rounded-2xl object-cover shadow-md" />
      </div>
      <div class="flex-1">
        <h1 class="text-3xl font-extrabold text-gray-900 leading-tight">{name}</h1>
        <p class="text-gray-500 mt-1">{academic_role} · Universidad El Bosque</p>
        <p class="text-sm text-gray-400 mt-1">{codec_role}</p>

        <div class="flex flex-wrap gap-2 mt-4">
          {lineIds.map(lid => {
            const line = LINES[lid as keyof typeof LINES];
            return line ? (
              <span class="text-xs px-3 py-1 rounded-full font-medium"
                style={`background-color: ${line.color}18; color: ${line.color}`}>
                {line.name_es}
              </span>
            ) : null;
          })}
        </div>

        <div class="flex flex-wrap gap-2 mt-4">
          {socialLinks.map(link => (
            <a href={link.href}
              target={link.href?.startsWith('mailto:') ? '_self' : '_blank'}
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded-lg transition-colors">
              <Icon name={link.icon} class="w-4 h-4 shrink-0" />
              <span>{link.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2">
        {bio_short_es && (
          <p class="text-lg text-gray-600 leading-relaxed mb-8 p-5 bg-gray-50 rounded-xl border-l-4 border-codec">
            {bio_short_es}
          </p>
        )}
        <div class="prose prose-gray max-w-none">
          <Content />
        </div>
      </div>

      <aside class="space-y-8">
        {interests_es && interests_es.length > 0 && (
          <div>
            <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Intereses</h2>
            <div class="flex flex-wrap gap-2">
              {interests_es.map(i => (
                <span class="text-xs bg-codec/10 text-codec px-2.5 py-1 rounded-full font-medium">{i}</span>
              ))}
            </div>
          </div>
        )}

        {education && education.length > 0 && (
          <div>
            <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Formación</h2>
            <ul class="space-y-3">
              {education.map(e => (
                <li class="border-l-2 border-gray-100 pl-3">
                  <p class="text-xs font-semibold text-gray-700">{e.degree}</p>
                  <p class="text-xs text-gray-500">{e.institution}</p>
                  <p class="text-xs text-gray-400">{e.year}</p>
                </li>
              ))}
            </ul>
          </div>
        )}

        {labEntries.length > 0 && (
          <div>
            <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Laboratorio</h2>
            {labEntries.map(l => l && (
              <a href={`/laboratorios/${toSlug(l.id)}`}
                class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
                <img src={l.data.logo_light} alt={l.data.short_name} class="h-6 object-contain" />
                <span class="text-sm font-medium text-gray-700">{l.data.short_name}</span>
              </a>
            ))}
          </div>
        )}

        {semilleroEntries.length > 0 && (
          <div>
            <h2 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Semillero</h2>
            {semilleroEntries.map(s => s && (
              <a href={`/semilleros/${toSlug(s.id)}`}
                class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
                {s.data.logo_light
                  ? <img src={s.data.logo_light} alt={s.data.short_name} class="h-6 object-contain" />
                  : <span class="text-sm font-bold" style={`color: ${s.data.color}`}>{s.data.short_name}</span>
                }
                <span class="text-sm font-medium text-gray-700">{s.data.short_name}</span>
              </a>
            ))}
          </div>
        )}
      </aside>
    </div>

    {myPublications.length > 0 && (
      <div class="mt-16 pt-12 border-t border-gray-100">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Publicaciones</h2>
            <p class="text-gray-500 mt-1 text-sm">
              {myPublications.length} publicaci{myPublications.length === 1 ? 'ón' : 'ones'}
            </p>
          </div>
          <a href="/publicaciones" class="text-sm font-semibold text-codec hover:underline">
            Ver todas →
          </a>
        </div>
        <div class="space-y-3">
          {myPublications.map(pub => <PublicationCard pub={pub} />)}
        </div>
      </div>
    )}

  </div>
</Base>
