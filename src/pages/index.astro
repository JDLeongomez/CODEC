---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ResearcherCard from '../components/ResearcherCard.astro';
import LabCard from '../components/LabCard.astro';
import SemilleroCard from '../components/SemilleroCard.astro';
import { LINES } from '../data/lines';
import { slug as toSlug } from '../utils';

const SHOW_TYPES = new Set(['article', 'book', 'book-chapter']);
const recentPubs = (await getCollection('publications'))
  .filter(p => SHOW_TYPES.has(p.data.pub_type))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
const pubTypeLabels: Record<string, string> = {
  article:        'Artículo',
  'book-chapter': 'Capítulo de libro',
  book:           'Libro',
};

const allResearchers = (await getCollection('researchers')).sort((a, b) => a.data.name.localeCompare(b.data.name, 'es'));
const resLeader      = allResearchers.filter(r =>  r.data.codec_role.includes('Líder'));
const resMembers     = allResearchers.filter(r => !r.data.codec_role.includes('Líder'));
const researchers    = allResearchers;
const labs        = await getCollection('labs');
const semilleros  = await getCollection('semilleros');
---

<Base title="Inicio">

  <!-- Hero -->
  <section class="bg-gray-950 text-white py-24 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <img src="/logos/CODEC_oscuro.png" alt="CODEC" class="h-96 mx-auto mb-8" />
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        CODEC: Ciencias Cognitivas y del Comportamiento
      </h1>
      <p class="inline-block bg-codec/20 text-codec text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
        Grupo A1 · Universidad El Bosque · Bogotá, Colombia
      </p>
      <p class="text-gray-300 text-lg leading-relaxed max-w-2xl mx-auto">
        Estudiamos la cognición y el comportamiento humano desde perspectivas evolutivas, neurocientíficas y neuropsicológicas, con énfasis en rigor metodológico y ciencia abierta.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {[
          { href: '/investigadores',       label: 'Integrantes' },
          { href: '/laboratorios',         label: 'Laboratorios' },
          { href: '/semilleros',           label: 'Semilleros' },
          { href: '/publicaciones',        label: 'Publicaciones' },
          { href: '/antiguos-integrantes', label: 'Historia' },
        ].map(link => (
          <a href={link.href}
            class="border border-gray-600 text-white font-semibold px-5 py-2.5 rounded-xl hover:bg-white/10 hover:border-gray-400 transition-colors text-sm">
            {link.label}
          </a>
        ))}
      </div>
      <div class="flex flex-wrap justify-center gap-3 mt-5">
        <a href="https://scienti.minciencias.gov.co/gruplac/jsp/visualiza/visualizagr.jsp?nro=00000000001446"
          target="_blank" rel="noopener noreferrer"
          class="text-xs text-gray-400 hover:text-codec border border-gray-800 hover:border-codec/40 px-3 py-1.5 rounded-lg transition-colors">
          GrupLAC · Minciencias
        </a>
        <a href="https://unbosque.portalinvestigacion.com/grupos/302"
          target="_blank" rel="noopener noreferrer"
          class="text-xs text-gray-400 hover:text-codec border border-gray-800 hover:border-codec/40 px-3 py-1.5 rounded-lg transition-colors">
          Portal de Investigación UEB
        </a>
      </div>
    </div>
  </section>

  <!-- Líneas de investigación -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">Líneas de Investigación</h2>
        <p class="text-gray-500 mt-2">Tres líneas complementarias que articulan el trabajo del grupo</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {Object.values(LINES).filter(l => l.id !== 'transversal').map(line => {
          const lineLabs = labs.filter(l => l.data.research_line === line.id);
          const lineSems = semilleros.filter(s => s.data.research_line === line.id);
          return (
            <div
              class="rounded-2xl p-6 border"
              style={`border-color: ${line.color}40; background: linear-gradient(135deg, ${line.color}08, white)`}
            >
              <div class="w-10 h-1 rounded-full mb-1" style={`background-color: ${line.color}`}></div>
              <p class="text-xs font-semibold mb-2" style={`color: ${line.color}`}>
                Línea {line.id.replace('line', '')}
              </p>
              <h3 class="font-bold text-gray-900 text-lg leading-snug mb-3">{line.name_es}</h3>
              {lineLabs.length > 0 && (
                <div class="mb-2">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Laboratorio{lineLabs.length > 1 ? 's' : ''}</p>
                  {lineLabs.map(l => (
                    <a href={`/laboratorios/${toSlug(l.id)}`} class="text-sm font-medium hover:underline" style={`color: ${line.color}`}>
                      {l.data.short_name}
                    </a>
                  ))}
                </div>
              )}
              {lineSems.length > 0 && (
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Semillero{lineSems.length > 1 ? 's' : ''}</p>
                  <div class="flex flex-wrap gap-2">
                    {lineSems.map(s => (
                      <a href={`/semilleros/${toSlug(s.id)}`} class="text-sm font-medium hover:underline" style={`color: ${line.color}`}>
                        {s.data.short_name}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>

      <!-- Transversal -->
      {(() => {
        const transLine = LINES.transversal;
        const transSems = semilleros.filter(s => s.data.research_line === 'transversal');
        return transSems.length > 0 ? (
          <div class="mt-6 rounded-2xl p-5 border flex flex-col sm:flex-row sm:items-center gap-4"
            style={`border-color: ${transLine.color}40; background: ${transLine.color}06`}>
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full shrink-0" style={`background-color: ${transLine.color}`}></div>
              <span class="font-semibold text-sm" style={`color: ${transLine.color}`}>Transversal a todas las líneas</span>
            </div>
            <div class="flex flex-wrap gap-2 sm:ml-2">
              {transSems.map(s => (
                <a href={`/semilleros/${toSlug(s.id)}`}
                  class="text-sm font-medium px-3 py-1 rounded-full border hover:opacity-80 transition-opacity"
                  style={`color: ${transLine.color}; border-color: ${transLine.color}50`}>
                  {s.data.short_name}
                </a>
              ))}
            </div>
          </div>
        ) : null;
      })()}
    </div>
  </section>

  <!-- Investigadores -->
  <section class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">Integrantes</h2>
          <p class="text-gray-500 mt-1">{researchers.length} integrantes del grupo</p>
        </div>
        <a href="/investigadores" class="text-sm font-semibold text-codec hover:underline">Ver todos →</a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-5">
        <div class="hidden sm:flex items-center gap-2">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest shrink-0">Líder</span>
          <span class="flex-1 h-px bg-gray-200"></span>
        </div>
        <div class="hidden sm:flex sm:col-span-3 items-center gap-2">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest shrink-0">Investigadoras/es</span>
          <span class="flex-1 h-px bg-gray-200"></span>
        </div>
        {[...resLeader, ...resMembers].map(r => <ResearcherCard researcher={r} />)}
      </div>
    </div>
  </section>

  <!-- Laboratorios -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">Laboratorios</h2>
          <p class="text-gray-500 mt-1">Unidades de investigación del grupo</p>
        </div>
        <a href="/laboratorios" class="text-sm font-semibold text-codec hover:underline">Ver todos →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {labs.map(lab => <LabCard lab={lab} />)}
      </div>
    </div>
  </section>

  <!-- Semilleros -->
  <section class="py-20 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">Semilleros</h2>
          <p class="text-gray-500 mt-1">Grupos de investigación formativa</p>
        </div>
        <a href="/semilleros" class="text-sm font-semibold text-codec hover:underline">Ver todos →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {semilleros.map(s => <SemilleroCard semillero={s} />)}
      </div>
    </div>
  </section>


  <!-- Publicaciones recientes -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">Publicaciones recientes</h2>
          <p class="text-gray-500 mt-1">Últimas publicaciones del grupo</p>
        </div>
        <a href="/publicaciones" class="text-sm font-semibold text-codec hover:underline">Ver todas →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPubs.map(pub => (
          <div class="group rounded-2xl border border-gray-100 p-6 hover:shadow-md transition-all hover:border-codec/20 bg-white flex flex-col gap-3">
            <div class="flex items-start justify-between gap-2">
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-codec/10 text-codec shrink-0">
                {pubTypeLabels[pub.data.pub_type] ?? pub.data.pub_type}
              </span>
              <span class="text-3xl font-black text-gray-100 tabular-nums leading-none">
                {pub.data.year}
              </span>
            </div>
            <a href={`/publicaciones/${toSlug(pub.id)}`}
              class="font-semibold text-gray-900 group-hover:text-codec transition-colors leading-snug">
              {pub.data.title}
            </a>
            <p class="text-xs text-gray-500 leading-relaxed">
              {pub.data.authors.slice(0, 3).join(', ')}{pub.data.authors.length > 3 ? ' et al.' : ''}
            </p>
            {pub.data.journal && (
              <p class="text-xs font-medium text-gray-500 italic mt-auto">{pub.data.journal}</p>
            )}
            {pub.data.doi && (
              <a href={`https://doi.org/${pub.data.doi}`} target="_blank" rel="noopener noreferrer"
                class="text-xs text-codec/60 hover:text-codec transition-colors">
                doi:{pub.data.doi}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
