---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PublicationCard from '../../components/PublicationCard.astro';

const publications = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));

const byYear: Record<number, typeof publications> = {};
for (const pub of publications) {
  if (!byYear[pub.data.year]) byYear[pub.data.year] = [];
  byYear[pub.data.year].push(pub);
}
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<Base title="Publicaciones">
  <div class="max-w-4xl mx-auto px-6 py-16">

    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900">Publicaciones</h1>
      <p class="text-gray-500 mt-2">
        {publications.length} publicacion{publications.length !== 1 ? 'es' : ''} del grupo CODEC
      </p>
    </div>

    {publications.length === 0 && (
      <p class="text-gray-400 text-center py-16">No hay publicaciones registradas aún.</p>
    )}

    <div class="space-y-14">
      {years.map(year => (
        <div>
          <div class="flex items-center gap-4 mb-5">
            <h2 class="text-2xl font-bold text-gray-900">{year}</h2>
            <div class="flex-1 h-px bg-gray-100"></div>
            <span class="text-sm text-gray-400">
              {byYear[year].length} publicaci{byYear[year].length === 1 ? 'ón' : 'ones'}
            </span>
          </div>
          <div class="space-y-3">
            {byYear[year].map(pub => <PublicationCard pub={pub} />)}
          </div>
        </div>
      ))}
    </div>

  </div>
</Base>
