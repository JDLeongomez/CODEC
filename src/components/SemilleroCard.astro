---
import { getEntry, type CollectionEntry } from 'astro:content';
import { slug } from '../utils';
import { LINES } from '../data/lines';

interface Props {
  semillero: CollectionEntry<'semilleros'>;
}

const { semillero } = Astro.props;
const { name, short_name, color, logo_light, research_line } = semillero.data;
const director = await getEntry(semillero.data.director);
const line = LINES[research_line as keyof typeof LINES];
---

<a
  href={`/semilleros/${slug(semillero.id)}`}
  class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col"
  style={`border-left: 4px solid ${color}`}
>
  <div class="p-5 flex-1 flex flex-col">
    <div class="flex items-center gap-3 mb-3">
      {logo_light ? (
        <img src={logo_light} alt={short_name} class="h-24 object-contain" />
      ) : (
        <span class="font-bold text-lg" style={`color: ${color}`}>{short_name}</span>
      )}
    </div>

    <h3 class="font-semibold text-sm text-gray-900 group-hover:text-gray-700 transition-colors leading-snug">
      {name}
    </h3>

    {director && (
      <p class="text-xs text-gray-500 mt-2">
        Director/a: <span class="font-medium text-gray-700">{director.data.name}</span>
      </p>
    )}

    {line && (
      <div class="mt-3">
        <span
          class="text-xs px-2 py-0.5 rounded-full font-medium"
          style={`background-color: ${color}18; color: ${color}`}
        >
          {research_line === 'transversal' ? 'Transversal' : line.name_es}
        </span>
      </div>
    )}
  </div>
</a>
