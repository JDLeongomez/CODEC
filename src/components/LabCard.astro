---
import { getEntry, type CollectionEntry } from 'astro:content';
import { slug } from '../utils';
import { LINES } from '../data/lines';

interface Props {
  lab: CollectionEntry<'labs'>;
}

const { lab } = Astro.props;
const { name, short_name, color, logo_light, research_line } = lab.data;
const director = await getEntry(lab.data.director);
const line = LINES[research_line as keyof typeof LINES];
---

<a
  href={`/laboratorios/${slug(lab.id)}`}
  class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col"
  style={`border-left: 4px solid ${color}`}
>
  <div class="p-6 flex-1 flex flex-col">
    <div class="flex items-start justify-between gap-4 mb-4">
      <img src={logo_light} alt={short_name} class="h-28 object-contain" />
      {line && (
        <span
          class="text-xs px-2 py-1 rounded-full font-medium shrink-0"
          style={`background-color: ${color}18; color: ${color}`}
        >
          {line.name_es}
        </span>
      )}
    </div>

    <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors leading-snug">
      {name}
    </h3>

    {director && (
      <p class="text-xs text-gray-500 mt-2">
        Director/a: <span class="font-medium text-gray-700">{director.data.name}</span>
      </p>
    )}
  </div>

  <div class="px-6 py-3 border-t border-gray-50 bg-gray-50/50">
    <span class="text-xs font-medium group-hover:text-codec transition-colors" style={`color: ${color}`}>
      Ver laboratorio →
    </span>
  </div>
</a>
