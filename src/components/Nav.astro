---
import { getCollection } from 'astro:content';
import { slug } from '../utils';

const labs       = await getCollection('labs');
const semilleros = await getCollection('semilleros');

const links = [
  { href: '/investigadores', label: 'Integrantes', children: null as null | { href: string; label: string }[] },
  {
    href: '/laboratorios',
    label: 'Laboratorios',
    children: [
      { href: '/laboratorios', label: 'Todos los laboratorios' },
      ...labs.map(l => ({ href: `/laboratorios/${slug(l.id)}`, label: l.data.short_name })),
    ],
  },
  {
    href: '/semilleros',
    label: 'Semilleros',
    children: [
      { href: '/semilleros', label: 'Todos los semilleros' },
      ...semilleros.map(s => ({ href: `/semilleros/${slug(s.id)}`, label: s.data.short_name })),
    ],
  },
  { href: '/publicaciones',       label: 'Publicaciones',      children: null as null | { href: string; label: string }[] },
  { href: '/antiguos-integrantes', label: 'Historia',          children: null as null | { href: string; label: string }[] },
];

const current = Astro.url.pathname;

const parentClass = (href: string) =>
  `px-4 py-2 rounded-md text-sm font-medium transition-colors ${
    current.startsWith(href)
      ? 'bg-codec/10 text-codec'
      : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
  }`;

const childClass = (href: string) =>
  `block px-4 py-2 text-sm font-medium transition-colors ${
    current === href
      ? 'bg-codec/10 text-codec'
      : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
  }`;

const mobileParentClass = (href: string) =>
  `px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
    current.startsWith(href)
      ? 'bg-codec/10 text-codec'
      : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
  }`;

const mobileChildClass = (href: string) =>
  `px-3 py-2 rounded-md text-sm transition-colors ${
    current === href
      ? 'text-codec'
      : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50'
  }`;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <a href="/" class="flex items-center gap-3 group">
      <img src="/logos/CODEC_oscuro.png" alt="CODEC" class="h-8" />
      <span class="text-sm font-semibold text-gray-500 group-hover:text-codec transition-colors">
        CODEC
      </span>
    </a>

    <nav class="hidden sm:flex items-center gap-1">
      {links.map(link => (
        link.children ? (
          <div class="relative group">
            <a
              href={link.href}
              class={`${parentClass(link.href)} flex items-center gap-1`}
            >
              {link.label}
              <svg class="w-3 h-3 mt-0.5 opacity-50" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
            <div class="absolute hidden group-hover:block top-full left-0 pt-1 z-50">
              <div class="bg-white rounded-md shadow-lg border border-gray-100 py-1 min-w-max">
                {link.children.map(child => (
                  <a href={child.href} class={childClass(child.href)}>
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={parentClass(link.href)}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>

    <button
      id="menu-toggle"
      class="sm:hidden p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg id="icon-open"  class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

  </div>

  <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-2 flex flex-col">
      {links.map(link => (
        link.children ? (
          <div>
            <a href={link.href} class={mobileParentClass(link.href)}>
              {link.label}
            </a>
            <div class="ml-3 pl-3 border-l-2 border-gray-100 flex flex-col mb-1">
              {link.children.map(child => (
                <a href={child.href} class={mobileChildClass(child.href)}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={mobileParentClass(link.href)}
          >
            {link.label}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
