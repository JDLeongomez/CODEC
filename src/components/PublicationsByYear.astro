---
import { getCollection } from 'astro:content';

const publications = await getCollection('publications');

type Group = 'articles' | 'books' | 'other';

const GROUPS: { key: Group; label: string; color: string; types: string[] }[] = [
  { key: 'articles', label: 'Artículos / Preprints', color: '#ffb600', types: ['article', 'preprint']              },
  { key: 'books',    label: 'Libros / Capítulos',    color: '#00a6b0', types: ['book', 'book-chapter']             },
  { key: 'other',    label: 'Otros',                  color: '#a451ff', types: ['conference', 'thesis', 'software', 'other']   },
];

const counts: Record<number, Record<Group, number>> = {};
for (const p of publications) {
  const year = p.data.year;
  if (!counts[year]) counts[year] = { articles: 0, books: 0, other: 0 };
  const group = GROUPS.find(g => g.types.includes(p.data.pub_type));
  if (group) counts[year][group.key]++;
}

const years    = Object.keys(counts).map(Number).sort((a, b) => a - b);
const maxCount = Math.max(...years.map(y => {
  const c = counts[y];
  return c.articles + c.books + c.other;
}));

// ── OpenAlex: citas por año ───────────────────────────────────────────────
type OAWork = { counts_by_year: { year: number; cited_by_count: number }[] };
const citsByYear: Record<number, number> = {};

const dois = publications.map(p => p.data.doi).filter(Boolean) as string[];
const BATCH = 25;
try {
  for (let i = 0; i < dois.length; i += BATCH) {
    const batch  = dois.slice(i, i + BATCH);
    const filter = `doi:${batch.join('|')}`;
    const url    = `https://api.openalex.org/works?filter=${filter}&select=counts_by_year&per_page=50&mailto=juanleongomez@gmail.com`;
    const res    = await fetch(url);
    if (!res.ok) continue;
    const data   = await res.json() as { results: OAWork[] };
    for (const work of data.results ?? []) {
      for (const row of work.counts_by_year ?? []) {
        citsByYear[row.year] = (citsByYear[row.year] ?? 0) + row.cited_by_count;
      }
    }
  }
} catch { /* silent: chart remains bars-only */ }

const hasCitations = Object.keys(citsByYear).length > 0;
const maxCitations = hasCitations ? Math.max(...years.map(y => citsByYear[y] ?? 0)) : 1;
// ─────────────────────────────────────────────────────────────────────────

const BAR_W = 24;
const GAP   = 5;
const H     = 130;
const PAD_L = 28;
const PAD_B = 26;
const PAD_T = 26;   // room for legend
const PAD_R = hasCitations ? 36 : 0;
const width  = PAD_L + years.length * (BAR_W + GAP) + PAD_R;
const height = PAD_T + H + PAD_B;
---

<div class="w-full overflow-x-auto">
  <svg
    viewBox={`0 0 ${width} ${height}`}
    class="w-full"
    style={`min-width: ${Math.min(width, 560)}px`}
    aria-label="Publicaciones y citas por año"
  >
    <!-- Leyenda barras -->
    {GROUPS.map((g, i) => (
      <>
        <rect x={PAD_L + i * 110} y={4} width={10} height={10} rx="2" fill={g.color} />
        <text x={PAD_L + i * 110 + 14} y={13} font-size="8.5" fill="#6b7280">{g.label}</text>
      </>
    ))}

    <!-- Leyenda citas -->
    {hasCitations && (
      <>
        <line x1={PAD_L + 3 * 110} y1={9} x2={PAD_L + 3 * 110 + 14} y2={9}
          stroke="#64748b" stroke-width="1.5" />
        <circle cx={PAD_L + 3 * 110 + 7} cy={9} r="2.5"
          fill="white" stroke="#64748b" stroke-width="1.5" />
        <text x={PAD_L + 3 * 110 + 18} y={13} font-size="8.5" fill="#6b7280">Citas (eje →)</text>
      </>
    )}

    <!-- Líneas guía (izquierda) -->
    {[0.25, 0.5, 0.75, 1].map(f => {
      const y   = PAD_T + H - f * H;
      const val = Math.round(f * maxCount);
      return (
        <>
          <line x1={PAD_L} y1={y} x2={width - PAD_R} y2={y} stroke="#e5e7eb" stroke-width="1" />
          <text x={PAD_L - 4} y={y + 4} text-anchor="end" font-size="7.5" fill="#9ca3af">{val}</text>
        </>
      );
    })}

    <!-- Eje Y derecho (citas) -->
    {hasCitations && (
      <>
        <line x1={width - PAD_R} y1={PAD_T} x2={width - PAD_R} y2={PAD_T + H}
          stroke="#e5e7eb" stroke-width="0.75" stroke-dasharray="2,2" />
        {[0.25, 0.5, 0.75, 1].map(f => {
          const y   = PAD_T + H - f * H;
          const val = Math.round(f * maxCitations);
          return (
            <text x={width - PAD_R + 4} y={y + 4} font-size="7.5" fill="#94a3b8">{val}</text>
          );
        })}
      </>
    )}

    <!-- Barras apiladas -->
    {years.map((year, i) => {
      const c   = counts[year];
      const x   = PAD_L + i * (BAR_W + GAP);
      const total = c.articles + c.books + c.other;
      let cumH  = 0;
      return (
        <>
          {GROUPS.map(g => {
            const count = c[g.key];
            if (count === 0) return null;
            const barH  = (count / maxCount) * H;
            const y     = PAD_T + H - cumH - barH;
            cumH += barH;
            return (
              <rect x={x} y={y} width={BAR_W} height={barH}
                fill={g.color} opacity="0.85"
                rx={cumH === barH ? '3 3 0 0' : '0'}
                class="hover:opacity-100 transition-opacity">
                <title>{year} – {g.label}: {count}</title>
              </rect>
            );
          })}
          {total > 0 && (
            <text x={x + BAR_W / 2}
              y={PAD_T + H - (total / maxCount) * H - 3}
              text-anchor="middle" font-size="7.5" fill="#6b7280">{total}</text>
          )}
          <text x={x + BAR_W / 2} y={PAD_T + H + PAD_B - 4}
            text-anchor="middle" font-size="8" fill="#9ca3af"
            transform={`rotate(-40, ${x + BAR_W / 2}, ${PAD_T + H + PAD_B - 4})`}>
            {year}
          </text>
        </>
      );
    })}

    <!-- Línea de citas -->
    {hasCitations && (() => {
      const pts = years
        .map((year, i) => {
          const cx = PAD_L + i * (BAR_W + GAP) + BAR_W / 2;
          const cy = PAD_T + H - ((citsByYear[year] ?? 0) / maxCitations) * H;
          return `${cx},${cy}`;
        })
        .join(' ');
      return (
        <polyline points={pts} fill="none" stroke="#64748b" stroke-width="1.5"
          stroke-linejoin="round" stroke-linecap="round" />
      );
    })()}

    <!-- Puntos de citas -->
    {hasCitations && years.map((year, i) => {
      const cits = citsByYear[year] ?? 0;
      const cx   = PAD_L + i * (BAR_W + GAP) + BAR_W / 2;
      const cy   = PAD_T + H - (cits / maxCitations) * H;
      return (
        <circle cx={cx} cy={cy} r="2.5" fill="white" stroke="#64748b" stroke-width="1.5">
          <title>{year} – Citas: {cits}</title>
        </circle>
      );
    })}
  </svg>
</div>
